# Wine Pair Content Intelligence Engine — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# --- Google Search Console ---
# Path to your Google Cloud service account JSON key file.
# Create at: https://console.cloud.google.com → IAM & Admin → Service Accounts
# Grant this service account "Restricted" access in Google Search Console.
GSC_SERVICE_ACCOUNT_KEY=config/service_account.json

# Your verified Search Console property URL (exact match, including trailing slash if used)
GSC_SITE_URL=https://thewinepairpodcast.com/

# --- YouTube Data API ---
# Create at: https://console.cloud.google.com → APIs & Services → Credentials → API Key
# Enable YouTube Data API v3 in the same project.
YOUTUBE_API_KEY=

# --- Website ---
# Your WordPress site URL for REST API crawl
SITE_URL=https://thewinepairpodcast.com
SITEMAP_URL=https://thewinepairpodcast.com/sitemap_index.xml

# --- Buzzsprout (Phase 3 — not required for Phase 1) ---
# Find at: https://www.buzzsprout.com/app → API
BUZZSPROUT_API_KEY=
BUZZSPROUT_PODCAST_ID=

# --- Reddit API (Phase 4 — not required for Phase 1) ---
# Register app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=WinePairContentIntelligence/1.0

# --- Report delivery (optional) ---
# Email address to send the weekly report to
REPORT_EMAIL=

# --- Paths ---
# Where to write the weekly report (relative to project root)
REPORTS_DIR=reports
DB_PATH=data/sqlite/intelligence.db
LOGS_DIR=logs
